{
  "name": "pm-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "sqlite:prepare": "node ./scripts/prepare-sqlite-path.mjs",
    "sqlite:init": "node ./scripts/sqlite-init.mjs",
    "prisma:push": "node ./scripts/prepare-sqlite-path.mjs && prisma db push",
    "prisma:migrate": "node ./scripts/prepare-sqlite-path.mjs && prisma migrate dev --name init_local_credentials",
    "sqlite:add": "tsx ./scripts/sqlite-add-user.ts",
    "sqlite:download": "node ./scripts/sharepoint-sqlite-sync.mjs download",
    "sqlite:upload": "node ./scripts/sharepoint-sqlite-sync.mjs upload",
    "fabric:connection": "tsx ./scripts/fabric-connection.ts",
    "fabric:preview:dim-producto": "tsx ./scripts/fabric-preview-dim-producto.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "mssql": "^12.5.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mssql": "^12.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^7.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "prisma"
    ]
  }
}
